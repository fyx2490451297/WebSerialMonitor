[Unit]
Description=Web Serial Monitor Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ethan
Group=ethan
WorkingDirectory=/home/ethan/Desktop/WebSerialMonitor
ExecStart=/home/ethan/Desktop/WebSerialMonitor/.venv/bin/python /home/ethan/Desktop/WebSerialMonitor/run.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target